# Django
DJANGO_SECRET_KEY=replace-me-with-a-unique-secret-key
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Banco de dados
# Use uma das abordagens abaixo.

# 1) URL unica do PostgreSQL
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/estoquepro

# 2) Campos separados
POSTGRES_DB=estoquepro
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_SSLMODE=prefer
DB_CONN_MAX_AGE=60
